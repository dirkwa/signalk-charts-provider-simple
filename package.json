{
  "name": "signalk-charts-provider-simple",
  "version": "1.6.1-beta.2",
  "description": "Simple Signal K chart provider for local MBTiles with web and download management",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test --test-force-exit test/**/*.test.js",
    "test:fixtures": "node test/fixtures/create-test-mbtiles.js",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write 'src/**/*.js' 'test/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'test/**/*.js'"
  },
  "license": "MIT",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-chart-plotters",
    "signalk-category-utility"
  ],
  "author": {
    "name": "Dirk Wahrheit"
  },
  "dependencies": {
    "@signalk/server-api": "^2.0.0",
    "better-sqlite3": "^12.0.0",
    "bluebird": "^3.5.1",
    "busboy": "^1.6.0",
    "lodash": "^4.17.11",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-charts-provider-simple"
  },
  "bugs": {
    "url": "https://github.com/dirkwa/signalk-charts-provider-simple/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "signalk": {
    "appIcon": "assets/charts_logo.png",
    "displayName": "Charts Provider Simple",
    "appstore": {
      "displayName": "Charts Provider Simple",
      "categories": [
        "utilities"
      ],
      "author": "Dirk Wahrheit",
      "description": "Simple Signal K chart provider for local MBTiles with web and download management"
    },
    "webapp": {
      "name": "Charts Provider Simple",
      "description": "Simple Signal K chart provider for local MBTiles with web and download management",
      "location": "/plugins/signalk-charts-provider-simple/"
    }
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4"
  }
}
